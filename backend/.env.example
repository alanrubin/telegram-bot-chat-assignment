# Copy this file to `.env` and fill in your values:  cp .env.example .env
#
# The real `.env` is git-ignored; never commit your token.

# Telegram bot token from BotFather (REQUIRED). The backend will not start without it.
TELEGRAM_BOT_TOKEN=

# --- Optional overrides (sensible defaults are built into the app; uncomment to change) ---

# Pin a specific Telegram chat id as the only allowed participant.
# Leave unset to let the first chat that messages the bot claim the single slot.
# TELEGRAM_ALLOWED_CHAT_ID=

# Comma-separated browser origins allowed by CORS.
# Default: http://localhost:5173,http://localhost:8080  (local Vite dev + Dockerised frontend)
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Logging level: DEBUG | INFO | WARNING | ERROR   (default: INFO)
# LOG_LEVEL=INFO
